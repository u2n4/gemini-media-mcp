# Required: Google Gemini API key (shared by VEO + NanoBanana servers)
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Backup key for automatic rotation on rate-limit
GEMINI_API_KEY_BACKUP=optional_backup_key_here

# VEO-specific: Output directory for generated videos (default: ~/veo-videos)
VIDEO_OUTPUT_DIR=./videos
